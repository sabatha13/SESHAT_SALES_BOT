{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "crons": [
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/abandoned-checkouts",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/wishlist-reminder",
      "schedule": "0 10 * * 1"
    }
  ]
}
